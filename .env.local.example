# Copy this file to .env.local and fill in the values.
# Then add the same variables in Vercel Dashboard → Project → Settings → Environment Variables.

# Google Analytics 4 Measurement ID
# Get it from: analytics.google.com → Admin → Data Streams → your stream → Measurement ID
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Google Search Console HTML-tag verification code
# Get it from: search.google.com/search-console → Add property → URL prefix → HTML tag
# Copy only the content="..." value (not the full <meta> tag)
NEXT_PUBLIC_GSC_VERIFICATION=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
